{
  "name": "docs",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "astro": "astro",
    "build": "astro check && astro build",
    "dev": "astro dev",
    "docs": "cd .. && npm i && cd docs && npm i && npm run generate && npm run build && cp _redirects dist/_redirects",
    "generate": "node _data/supporters.cjs --write-supporters-json",
    "prelint:knip": "npm install",
    "lint:knip": "knip --cache",
    "preview": "astro preview",
    "start": "astro dev"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/starlight": "^0.38.4",
    "astro": "^6.1.9",
    "starlight-package-managers": "^0.12.0",
    "typescript": "^6.0.0"
  },
  "devDependencies": {
    "debug": "^4.4.3",
    "knip": "^6.0.0"
  }
}
